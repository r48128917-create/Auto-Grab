-- ==========================================
-- 3. Dragging Logic
-- ==========================================
local dragging, dragInput, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- ==========================================
-- 4. Main Loop & Syncing Logic
-- ==========================================
local function autoGrabLoop()
    while isAutoGrabbing do
        local prompt = findNearestStealPrompt()
        if prompt then
            StatusText.Text = "STATUS: GRABBING..."
            StatusText.TextColor3 = Color3.fromRGB(0, 180, 255)
            
            local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Linear)
            local tween = TweenService:Create(ProgressFill, tweenInfo, {Size = UDim2.new(1, 0, 1, 0)})
            tween:Play()
            
            triggerPrompt(prompt)
            task.wait(0.05)
            
            ProgressFill.Size = UDim2.new(0, 0, 1, 0)
            task.wait(stealCooldown)
        else
            StatusText.Text = "STATUS: SEARCHING..."
            StatusText.TextColor3 = Color3.fromRGB(150, 150, 160)
            ProgressFill.Size = UDim2.new(0, 0, 1, 0)
            task.wait(0.1)
        end
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    isAutoGrabbing = not isAutoGrabbing
    
    if isAutoGrabbing then
        ToggleBtn.Text = "STOP"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
        task.spawn(autoGrabLoop)
    else
        ToggleBtn.Text = "START"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(40, 200, 120)
        StatusText.Text = "STATUS: WAITING"
        StatusText.TextColor3 = Color3.fromRGB(150, 150, 160)
        ProgressFill.Size = UDim2.new(0, 0, 1, 0)
    end
end)
